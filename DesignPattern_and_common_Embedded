		return random;
	}
};

class update200MS : public TemperatureStrategy {
private:
	int cnt200MS = 0;

public:
	
	int execute(void) override 
	{
		if (cnt200MS < 2) {
			cnt200MS++;
			printf("update 200ms couting-up \n");
		
		}else {
			printf("update 200ms achieved \n");
			cnt200MS = 0;
		}
		return 1;
	}
};


class TemperatureDeviceRun {
private:
	TemperatureStrategy* Currentstrategy;
public:
	void setStrategy(TemperatureStrategy* SelectStrategy)
	{
		Currentstrategy = SelectStrategy;
	}
	 

	int executeStrategy(void)//ruri adrinal: this is execute strategy which calling in main after inheritance,calling depend on which strategy we had choice in above
	{
		printf("function calling depend on which strategy we had choice in above %d", Currentstrategy);
		return(Currentstrategy->execute());
		
	}
};

int main()
