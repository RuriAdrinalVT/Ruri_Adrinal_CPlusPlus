#include <condition_variable>
#include <iostream>
#include <mutex>
#include <queue>

// Thread-safe queue
template <typename T>
class TSDataExchange {
private:
    unsigned char volatile SensorAddress = (unsigned char*) 0x8111;//ruri : for example
    // Underlying queue
    std::queue<T> m_queue;//ruri: queue object instantiate

    // mutex for thread synchronization
    std::mutex m_mutex;

    // Condition variable for signaling
    std::condition_variable m_cond;

public:

    //ruri: get data from IO
    int getSensorData(void){
	return(SensorAddress);        
    }    
    // Pushes an element to the queue
    void pushSensorData(T Sensoritem)
    {
	
        std::unique_lock<std::mutex> lock(m_mutex);
        m_queue.push(Sensoritem);//queue object method 
        m_cond.notify_one();
    }
    T popData()
    {

        std::unique_lock<std::mutex> lock(m_mutex);
        m_cond.wait(lock,
                    [this]() { return !m_queue.empty(); });

        T item = m_queue.front();
        m_queue.popData();
        return item;
    }
};

int main()
{
    TSDataExchange<int> Tqueue;

    //ruri: store data/push sensor data
    Tqueue.push(Tqueue.getSensorData());
    Tqueue.push(Tqueue.getSensorData());
    Tqueue.push(Tqueue.getSensorData());

    // ruri: pop and getsome sensor data
    std::cout << Tqueue.pop() << std::endl;
    std::cout << Tqueue.pop() << std::endl;
    std::cout << Tqueue.pop() << std::endl;

    return 0;
}

